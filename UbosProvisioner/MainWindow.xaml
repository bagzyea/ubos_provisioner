<Window x:Class="UbosProvisioner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UBOS Device Provisioner" Height="950" Width="1500"
        WindowStartupLocation="CenterScreen">
        
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" ResizeBorderThickness="6" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Title Bar Control Buttons -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowCloseBtn" TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgLight}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource CardBg}">
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="UBOS Device Provisioner" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="◑" Width="46" Style="{StaticResource WindowControlBtn}" Click="ToggleTheme_Click" ToolTip="Toggle Light/Dark Theme" />
                    <Button Content="—" Width="46" Style="{StaticResource WindowControlBtn}" Click="MinBtn_Click"/>
                    <Button Content="☐" Width="46" Style="{StaticResource WindowControlBtn}" Click="MaxBtn_Click"/>
                    <Button Content="✕" Width="46" Style="{StaticResource WindowCloseBtn}" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main App Content -->
            <DockPanel Grid.Row="1">

            <!-- Device Control Panel -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,10,20,10">
                <Button Content="Refresh Devices" Command="{Binding RefreshDevicesCommand}" Margin="0,0,10,0" />
                <Button Content="Start Polling" Command="{Binding StartPollingCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,10,0" />
                <Button Content="Stop Polling" Command="{Binding StopPollingCommand}" Style="{StaticResource SecondaryButton}" />
            </StackPanel>

            <!-- Tabs: Provisioning vs De-Provisioning -->
            <TabControl Margin="20,10,20,20">
                <!-- TAB 1: PROVISIONING -->
                <TabItem Header="Provisioning">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Devices (70%) and Operation Logs (30%) -->
                        <Grid Grid.Column="0" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*" />
                                <RowDefinition Height="3*" />
                            </Grid.RowDefinitions>

                            <!-- Devices Grid (70%) -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="Select Devices to Provision:" FontWeight="Bold" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="Select All" Command="{Binding SelectAllDevicesCommand}" Padding="10,8" FontSize="11" Margin="0,0,10,0" />
                                        <Button Content="Deselect All" Command="{Binding DeselectAllDevicesCommand}" Padding="10,8" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding Devices}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected}" Width="40" />
                                        <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="130" />
                                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="130" />
                                        <DataGridTextColumn Header="Battery" Binding="{Binding BatteryLevel}" Width="60" />
                                        <DataGridTextColumn Header="State" Binding="{Binding ConnectionState}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>

                            <!-- Operation Logs (30%) -->
                            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Operation Log:" FontWeight="Bold" Margin="0,0,0,10" />
                                <DataGrid ItemsSource="{Binding ProvisioningLog}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Device" Binding="{Binding DeviceSerial}" Width="90" />
                                        <DataGridTextColumn Header="Operation" Binding="{Binding Operation}" Width="100" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Grid>

                        <!-- Right: Provisioning Config -->
                        <Border Grid.Column="1" Margin="10" Background="{DynamicResource CardBg}" Padding="20" CornerRadius="12" Effect="{DynamicResource CardShadow}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="Provisioning Config" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" />

                                <TextBlock Text="APK Files:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <ListBox Grid.Column="0" ItemsSource="{Binding ApkPaths}" Padding="6" FontSize="11" Height="60" />
                                    <Button Grid.Column="1" Content="Add APKs" Command="{Binding SelectApkCommand}" Margin="8,0,0,0" Padding="8,8" FontSize="11" />
                                </Grid>

                                <TextBlock Text="App Data:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding AppDataPath}" IsReadOnly="True" Padding="6" FontSize="11" />
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding SelectAppDataCommand}" Margin="8,0,0,0" Padding="8,8" FontSize="11" />
                                </Grid>

                                <TextBlock Text="TPK Folder:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding TpkFolderPath}" IsReadOnly="True" Padding="6" FontSize="11" />
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding SelectTpkFolderCommand}" Margin="8,0,0,0" Padding="8,8" FontSize="11" />
                                </Grid>

                                <TextBlock Text="TPK Distribution:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <ComboBox SelectedValue="{Binding SelectedTpkMode}" Margin="0,0,0,15" Padding="6" FontSize="11">
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Sequential</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">RoundRobin</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Random</System:String>
                                </ComboBox>

                                <TextBlock Text="Device PIN (optional):" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <TextBox Text="{Binding DevicePin}" Padding="6" Margin="0,0,0,15" FontSize="11"
                                         ToolTip="Set a PIN lock on device. Leave blank to skip." />

                                <TextBlock Text="APN Settings (optional):" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <TextBox Text="{Binding ApnName}" Padding="6" Margin="0,0,0,5" FontSize="11"
                                         ToolTip="APN display name" />
                                <TextBox Text="{Binding ApnValue}" Padding="6" Margin="0,0,0,5" FontSize="11"
                                         ToolTip="APN string (e.g. internet)" />
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding ApnMcc}" Padding="6" FontSize="11" ToolTip="Mobile Country Code (MCC)" />
                                    <TextBox Grid.Column="2" Text="{Binding ApnMnc}" Padding="6" FontSize="11" ToolTip="Mobile Network Code (MNC)" />
                                </Grid>
                                <TextBox Text="{Binding ApnType}" Padding="6" Margin="0,0,0,15" FontSize="11"
                                         ToolTip="APN type (default: 'default')" />

                                <Button Content="Start Provisioning" Command="{Binding StartProvisioningCommand}"
                                        Style="{StaticResource SuccessButton}"
                                        IsEnabled="{Binding IsProvisioning, Converter={StaticResource InverseBoolConverter}}"
                                        Padding="12,10" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Stretch" />

                                <Button Content="Cancel" Command="{Binding CancelProvisioningCommand}"
                                        Style="{StaticResource DangerButton}"
                                        IsEnabled="{Binding IsProvisioning}"
                                        Padding="12,10" FontSize="12" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: DE-PROVISIONING -->
                <TabItem Header="De-Provisioning">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Devices (70%) and Operation Logs (30%) -->
                        <Grid Grid.Column="0" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*" />
                                <RowDefinition Height="3*" />
                            </Grid.RowDefinitions>

                            <!-- Devices Grid (70%) -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="Select Devices to De-Provision:" FontWeight="Bold" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="Select All" Command="{Binding SelectAllDevicesCommand}" Padding="10,8" FontSize="11" Margin="0,0,10,0" />
                                        <Button Content="Deselect All" Command="{Binding DeselectAllDevicesCommand}" Padding="10,8" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding Devices}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected}" Width="40" />
                                        <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="130" />
                                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="130" />
                                        <DataGridTextColumn Header="Battery" Binding="{Binding BatteryLevel}" Width="60" />
                                        <DataGridTextColumn Header="State" Binding="{Binding ConnectionState}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>

                            <!-- Operation Logs (30%) -->
                            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Operation Log:" FontWeight="Bold" Margin="0,0,0,10" />
                                <DataGrid ItemsSource="{Binding ProvisioningLog}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Device" Binding="{Binding DeviceSerial}" Width="90" />
                                        <DataGridTextColumn Header="Operation" Binding="{Binding Operation}" Width="100" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Grid>

                        <!-- Right: De-Provisioning Config -->
                        <Border Grid.Column="1" Margin="10" Background="{DynamicResource CardBg}" Padding="20" CornerRadius="12" Effect="{DynamicResource CardShadow}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="De-Provisioning Config" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" />

                                <TextBlock Text="Extract Data Output:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding ExtractDataOutputPath}" IsReadOnly="True" Padding="6" FontSize="11" />
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding SelectExtractDataOutputCommand}" Margin="8,0,0,0" Padding="8,8" FontSize="11" />
                                </Grid>

                                <TextBlock Text="Info:" Margin="0,0,0,5" FontWeight="Bold" FontSize="12" />
                                <TextBlock Text="1. Extracts all data from /sdcard/Android/data/" Margin="0,0,0,5" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock Text="2. Performs factory reset" Margin="0,0,0,5" FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock Text="3. FRP will activate if a Google/MDM account is signed in" Margin="0,0,0,15" FontSize="11" Foreground="{DynamicResource Red}" FontWeight="Bold" />

                                <Button Content="Start De-Provisioning" Command="{Binding StartDeProvisioningCommand}"
                                        Style="{StaticResource DangerButton}"
                                        IsEnabled="{Binding IsDeProvisioning, Converter={StaticResource InverseBoolConverter}}"
                                        Padding="12,10" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Stretch" />

                                <Button Content="Cancel" Command="{Binding CancelDeProvisioningCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding IsDeProvisioning}"
                                        Padding="12,10" FontSize="12" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 3: SETTINGS -->
                <TabItem Header="Settings">
                    <Border Margin="20" Background="{DynamicResource CardBg}" Padding="24" CornerRadius="12" Effect="{DynamicResource CardShadow}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1">
                        <StackPanel MaxWidth="500" VerticalAlignment="Top">
                            <TextBlock Text="Application Settings" FontWeight="Bold" FontSize="16" Margin="0,0,0,20" />

                            <TextBlock Text="Max Concurrent Devices:" FontWeight="Bold" Margin="0,0,0,5" />
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="{Binding Settings.MaxConcurrentDevices}" TextAlignment="Right" VerticalAlignment="Center" />
                                <Slider Grid.Column="0" Minimum="1" Maximum="10" Value="{Binding Settings.MaxConcurrentDevices, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                            </Grid>

                            <TextBlock Text="Device Poll Interval (ms):" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Text="{Binding Settings.DevicePollIntervalMs, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15" />

                            <TextBlock Text="Logs Directory:" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Text="{Binding Settings.LogsDirectory}" Padding="8" Margin="0,0,0,15" IsReadOnly="True" />

                            <TextBlock Text="Platform Tools Path:" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Text="{Binding Settings.PlatformToolsPath}" Padding="8" Margin="0,0,0,20" IsReadOnly="True" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Button Content="Save Settings" Command="{Binding Settings.SaveSettingsCommand}" Style="{StaticResource SuccessButton}" Padding="12,10" FontSize="12" Margin="0,0,10,0" />
                                <Button Content="Reset to Defaults" Command="{Binding Settings.ResetToDefaultsCommand}" Style="{StaticResource SecondaryButton}" Padding="12,10" FontSize="12" />
                            </StackPanel>

                            <TextBlock Text="{Binding Settings.StatusMessage}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- TAB 4: LOGS -->
                <TabItem Header="Logs">
                    <DockPanel Margin="20">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Reports will be saved to: " VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding Settings.LogsDirectory}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource Emerald}" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="Export Operation Log" Command="{Binding ExportOperationLogCommand}" Padding="12,10" FontSize="12" Margin="0,0,10,0" />
                            <Button Content="Open Logs Folder" Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource SuccessButton}" Padding="12,10" FontSize="12" Margin="0,0,10,0" />
                            <Button Content="Clear Display" Command="{Binding ClearProvisioningLogCommand}" Style="{StaticResource SecondaryButton}" Padding="12,10" FontSize="12" />
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top" Text="Recent Log Files:" FontWeight="Bold" Margin="0,0,0,10" />
                        <ListBox Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource ControlBg}">
                            <ListBoxItem>provisioning_summary_20260401_120530.csv</ListBoxItem>
                            <ListBoxItem>provisioning_summary_20260401_110230.csv</ListBoxItem>
                            <ListBoxItem>device_audit_20260401_100100.csv</ListBoxItem>
                        </ListBox>
                    </DockPanel>
                </TabItem>

                <!-- TAB 5: DEVICE INFO -->
                <TabItem Header="Device Info">
                    <DockPanel Margin="20">
                        <TextBlock DockPanel.Dock="Top" Text="Connected Devices Details:" FontWeight="Bold" Margin="0,0,0,10" />
                        <DataGrid ItemsSource="{Binding Devices}" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="150" />
                                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="150" />
                                <DataGridTextColumn Header="Battery %" Binding="{Binding BatteryLevel}" Width="80" />
                                <DataGridTextColumn Header="Storage (KB)" Binding="{Binding StorageFree}" Width="120" />
                                <DataGridTextColumn Header="State" Binding="{Binding ConnectionState}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- TAB 6: DEVICE RECOVERY & AUDIT -->
                <TabItem Header="Device Recovery" DataContext="{Binding DeviceAudit}">
                    <DockPanel Margin="20">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                            <TextBlock Text="Device Recovery &amp; Lock Audit" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="400" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Audit Results -->
                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="Audit Results:" FontWeight="Bold" Margin="0,0,0,10" />
                                <DataGrid ItemsSource="{Binding AuditReports}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Serial" Binding="{Binding Serial}" Width="130" />
                                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="130" />
                                        <DataGridCheckBoxColumn Header="Locked?" Binding="{Binding IsScreenLocked}" Width="70" />
                                        <DataGridCheckBoxColumn Header="MDM?" Binding="{Binding HasDeviceAdmin}" Width="70" />
                                        <DataGridCheckBoxColumn Header="FRP?" Binding="{Binding IsFrpActive}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>

                            <!-- Right: Recovery Options -->
                            <Border Grid.Column="1" Margin="10,0,0,0" Background="{DynamicResource CardBg}" Padding="20" CornerRadius="12" Effect="{DynamicResource CardShadow}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="Recovery Actions" FontWeight="Bold" FontSize="12" Margin="0,0,0,15" />

                                    <TextBlock Text="Device Serial:" FontWeight="Bold" Margin="0,0,0,5" FontSize="11" />
                                    <TextBox Text="{Binding SelectedDeviceSerial}" Padding="8" Margin="0,0,0,10" />

                                    <Button Content="Audit Device" Command="{Binding AuditSingleDeviceCommand}"
                                            Padding="12,10" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Stretch" />

                                    <Separator Margin="0,15" Background="{DynamicResource BorderLight}" />

                                    <TextBlock Text="Clear Lock (with PIN):" FontWeight="Bold" Margin="0,0,0,5" FontSize="11" />
                                    <TextBox Text="{Binding PinForUnlock}" Padding="8" Margin="0,0,0,5" />
                                    <Button Content="Clear Lock" Command="{Binding ClearLockCommand}"
                                            Padding="12,10" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Stretch" />

                                    <Separator Margin="0,15" Background="{DynamicResource BorderLight}" />

                                    <TextBlock Text="Factory Reset:" FontWeight="Bold" Margin="0,0,0,10" FontSize="11" />
                                    <Button Content="Reboot to Recovery" Command="{Binding RebootToRecoveryCommand}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="12,10" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Stretch" />

                                    <Button Content="Cancel" Command="{Binding CancelAuditCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,10" FontSize="12" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Details Panel -->
                        <TextBlock DockPanel.Dock="Bottom" Text="Remediation Instructions:" FontWeight="Bold" Margin="0,15,0,5" FontSize="12" />
                        <TextBox DockPanel.Dock="Bottom" Text="{Binding AuditDetails}" IsReadOnly="True" TextWrapping="Wrap" Padding="10" Margin="0,0,0,0" Background="{DynamicResource ControlBgHover}" Foreground="{DynamicResource TextPrimary}" />
                    </DockPanel>
                </TabItem>
            </TabControl>

        </DockPanel>
        </Grid>
    </Border>
</Window>
